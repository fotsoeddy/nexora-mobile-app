DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=generate-me-with-python-c-from-django.core.management.utils-import-get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
TIME_ZONE=UTC

# DB_ENGINE: sqlite or postgresql
DB_ENGINE=sqlite
POSTGRES_DB=nexora
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

JWT_ACCESS_MINUTES=10
JWT_REFRESH_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
AUTH_REQUIRE_EMAIL_VERIFIED=True
PASSWORD_RESET_TIMEOUT_SECONDS=3600
THROTTLE_LOGIN_RATE=5/min
THROTTLE_FORGOT_RATE=5/min

# Dev: keep console backend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@nexora.local

# URLs used in email links
FRONTEND_VERIFY_URL=http://localhost:8000/api/auth/email/verify/confirm
FRONTEND_RESET_URL=http://localhost:3000/reset-password
